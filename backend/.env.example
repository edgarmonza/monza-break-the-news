# API Keys
GOOGLE_API_KEY=AIza...          # Gemini — embeddings (free tier)
ANTHROPIC_API_KEY=sk-ant-...    # Claude — thread generation & chat
# OPENAI_API_KEY=sk-proj-...   # (Optional, no longer required)

# Supabase (Fase 3 - Database)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redis (Opcional - para cache)
REDIS_URL=redis://localhost:6379/0

# Apify (Google News scraper — replaces custom scrapers)
APIFY_API_TOKEN=apify_api_...
USE_APIFY=true

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-app.vercel.app

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
SCRAPE_INTERVAL_MINUTES=15

# Scheduler (auto-update pipeline)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=2
SCHEDULER_COUNTRIES=CO,LATAM
# Add more countries as you scale: CO,MX,AR,CL,PE,EC,LATAM
